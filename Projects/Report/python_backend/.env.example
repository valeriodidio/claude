# ---- MySQL (yeppon_stats) ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=reports_reader
DB_PASSWORD=change_me
DB_NAME=yeppon_stats

# ---- App ----
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=false

# ---- Security ----
# Token condiviso con l'ASP (passato come header X-Internal-Token o query ?token=...)
# Serve SOLO per impedire chiamate esterne se il servizio viene esposto per errore.
# L'autenticazione utente vera resta sull'ASP.
INTERNAL_TOKEN=change_me_long_random_string

# CORS: lascia vuoto se chiami da server-to-server, oppure metti il dominio dell'admin
ALLOWED_ORIGINS=

# Pagina HTML di test locale su /static/test_turnover.html.
# In produzione DEVE restare false: l'UI ufficiale e' servita dall'admin ASP
# (actual_turnover_general.asp) via reverse proxy IIS.
# Abilitare solo per debug in dev/staging.
ENABLE_STATIC_TEST_UI=false

# Logging
LOG_LEVEL=INFO
